{
  "v": 1,
  "_comment": "TypeScript template (dynamos-front Vite/dev, dynamos-snapshot, jira-claude, packages). pnpm/npm install-family is ask (mutates node_modules + lockfile); test/build/lint/tsc are allow. Shlex-prefix note: Bash(pnpm) alone would match every pnpm subcommand, so we enumerate explicit safe subcommands.",
  "model": "claude-opus-4-7",
  "provider": "anthropic",
  "permissions": {
    "deny": [
      "Read(**/.env)", "Read(**/.env.*)", "Read(**/*.pem)", "Read(**/*.key)",
      "Read(**/.ssh/**)", "Read(**/credentials.json)", "Read(**/vault.yml)",
      "Read(**/vault/**)", "Read(**/secrets/**)",
      "Write(**/.env)", "Write(**/.env.*)", "Write(**/*.pem)", "Write(**/*.key)",
      "Write(**/.ssh/**)", "Write(**/credentials.json)",
      "Edit(**/.env)", "Edit(**/.env.*)", "Edit(**/*.pem)", "Edit(**/*.key)",
      "Edit(**/.ssh/**)", "Edit(**/credentials.json)",
      "Bash(git push)", "Bash(git push --force)", "Bash(git push -f)",
      "Bash(git push origin main)", "Bash(git push origin dev)", "Bash(git push origin qa)",
      "Bash(git push origin HEAD:main)", "Bash(git push origin HEAD:dev)", "Bash(git push origin HEAD:qa)",
      "Bash(npm publish)",
      "Bash(pnpm publish)",
      "Bash(yarn publish)"
    ],
    "allow": [
      "Read(**)", "Glob(**)", "Grep(**)",
      "Bash(ls)", "Bash(pwd)", "Bash(cat)", "Bash(head)", "Bash(tail)", "Bash(wc)",
      "Bash(file)", "Bash(stat)", "Bash(tree)",
      "Bash(git status)", "Bash(git log)", "Bash(git diff)", "Bash(git show)",
      "Bash(git branch)", "Bash(git blame)", "Bash(git remote)", "Bash(git fetch)",
      "Bash(git rev-parse)", "Bash(git ls-files)",
      "Bash(gh pr create)", "Bash(gh pr view)", "Bash(gh pr list)", "Bash(gh pr checks)",
      "Bash(gh issue list)", "Bash(gh issue view)",
      "Bash(pnpm test)",
      "Bash(pnpm run test)",
      "Bash(pnpm lint)",
      "Bash(pnpm run lint)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm run typecheck)",
      "Bash(pnpm run build)",
      "Bash(pnpm list)",
      "Bash(pnpm why)",
      "Bash(npm test)",
      "Bash(npm run test)",
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run build)",
      "Bash(npm ls)",
      "Bash(yarn test)",
      "Bash(yarn lint)",
      "Bash(yarn typecheck)",
      "Bash(tsc)",
      "Bash(tsc --build)",
      "Bash(tsc --noEmit)",
      "Bash(vite build)",
      "Bash(eslint)",
      "Bash(prettier --check)",
      "Bash(node --version)"
    ],
    "ask": [
      "Write(**)", "Edit(**)",
      "Bash(scp)", "Bash(rsync)", "Bash(ssh)", "Bash(sftp)",
      "Bash(rm)", "Bash(mv)", "Bash(cp)", "Bash(chmod)", "Bash(chown)", "Bash(sudo)",
      "Bash(pnpm install)",
      "Bash(pnpm add)",
      "Bash(pnpm remove)",
      "Bash(pnpm update)",
      "Bash(pnpm i)",
      "Bash(npm install)",
      "Bash(npm i)",
      "Bash(npm ci)",
      "Bash(npm uninstall)",
      "Bash(npm update)",
      "Bash(yarn install)",
      "Bash(yarn add)",
      "Bash(yarn remove)",
      "Bash(yarn upgrade)"
    ]
  },
  "harness": {
    "plan_gate": {
      "enabled": true,
      "patterns": ["**/*.xml", "**/*.ftl", "**/*.sql", "**/migrations/**"],
      "tools": ["Edit", "Write"]
    }
  }
}
