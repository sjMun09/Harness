{
  "v": 1,
  "_comment": "Generic template for dynamos-configuration, dynamos-monitoring, dynamosconvert (109MB JS), and any repo without a language-specific template. Reads everything, writes/edits ask, secrets deny, git push deny. Appropriate for config-heavy and mixed repos.",
  "model": "claude-opus-4-7",
  "provider": "anthropic",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.ssh/**)",
      "Read(**/credentials.json)",
      "Read(**/vault.yml)",
      "Read(**/vault/**)",
      "Read(**/secrets/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/.ssh/**)",
      "Write(**/credentials.json)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/.ssh/**)",
      "Edit(**/credentials.json)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force-with-lease)",
      "Bash(terraform destroy)",
      "Bash(docker push)",
      "Bash(docker run --privileged)",
      "Bash(gh release delete)",
      "Bash(gh workflow disable)"
    ],
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(cat)",
      "Bash(head)",
      "Bash(tail)",
      "Bash(wc)",
      "Bash(file)",
      "Bash(stat)",
      "Bash(tree)",
      "Bash(git status)",
      "Bash(git log)",
      "Bash(git diff)",
      "Bash(git show)",
      "Bash(git branch)",
      "Bash(git blame)",
      "Bash(git remote)",
      "Bash(git fetch)",
      "Bash(git rev-parse)",
      "Bash(git ls-files)",
      "Bash(gh pr create)",
      "Bash(gh pr view)",
      "Bash(gh pr list)",
      "Bash(gh pr checks)",
      "Bash(gh issue list)",
      "Bash(gh issue view)",
      "Bash(jq)",
      "Bash(yq)",
      "Bash(diff)",
      "Bash(sort)",
      "Bash(uniq)",
      "Bash(terraform plan)",
      "Bash(terraform validate)",
      "Bash(terraform fmt -check)",
      "Bash(terraform show)",
      "Bash(terraform state list)",
      "Bash(terraform version)",
      "Bash(kubectl get)",
      "Bash(kubectl describe)",
      "Bash(kubectl logs)",
      "Bash(kubectl config view)",
      "Bash(kubectl version)",
      "Bash(helm list)",
      "Bash(helm status)",
      "Bash(helm show)",
      "Bash(helm version)",
      "Bash(docker ps)",
      "Bash(docker images)",
      "Bash(docker inspect)",
      "Bash(docker logs)",
      "Bash(docker version)",
      "Bash(aws s3 ls)",
      "Bash(aws sts get-caller-identity)",
      "Bash(gcloud auth list)",
      "Bash(gcloud config list)",
      "Bash(gh api repos)",
      "Bash(gh api user)"
    ],
    "ask": [
      "Bash(git push)",
      "Write(**)",
      "Edit(**)",
      "Bash(scp)",
      "Bash(rsync)",
      "Bash(ssh)",
      "Bash(sftp)",
      "Bash(rm)",
      "Bash(mv)",
      "Bash(cp)",
      "Bash(chmod)",
      "Bash(chown)",
      "Bash(sudo)",
      "Bash(curl -X POST)",
      "Bash(curl -X PUT)",
      "Bash(curl -X DELETE)",
      "Bash(wget)",
      "Bash(terraform apply)",
      "Bash(terraform state rm)",
      "Bash(kubectl apply)",
      "Bash(kubectl delete)",
      "Bash(kubectl exec)",
      "Bash(kubectl replace)",
      "Bash(kubectl patch)",
      "Bash(kubectl edit)",
      "Bash(kubectl rollout undo)",
      "Bash(helm install)",
      "Bash(helm upgrade)",
      "Bash(helm uninstall)",
      "Bash(helm rollback)",
      "Bash(docker rm)",
      "Bash(docker rmi)",
      "Bash(docker system prune)",
      "Bash(docker volume rm)",
      "Bash(docker image prune)",
      "Bash(aws s3 rm)",
      "Bash(aws s3 cp)",
      "Bash(aws s3 sync)",
      "Bash(aws iam)",
      "Bash(aws ec2 terminate-instances)",
      "Bash(aws ec2 stop-instances)",
      "Bash(aws rds delete-db-instance)",
      "Bash(gcloud iam)",
      "Bash(gcloud compute instances delete)",
      "Bash(gh release create)",
      "Bash(gh workflow run)",
      "Bash(gh secret set)",
      "Bash(gh secret delete)",
      "Bash(gh repo delete)",
      "Bash(gh api -X POST)",
      "Bash(gh api -X PUT)",
      "Bash(gh api -X DELETE)",
      "Bash(gh api -X PATCH)"
    ]
  },
  "harness": {
    "plan_gate": {
      "enabled": true,
      "patterns": [
        "**/*.xml",
        "**/*.ftl",
        "**/*.sql",
        "**/migrations/**",
        "**/*.yml",
        "**/*.yaml"
      ],
      "tools": [
        "Edit",
        "Write"
      ]
    }
  },
  "hooks": {
    "pre_tool_use": [
      {
        "event": "pre_tool_use",
        "command": "bash scripts/harness-git-push-guard.sh",
        "timeout_ms": 3000,
        "on_timeout": "deny"
      }
    ]
  }
}
