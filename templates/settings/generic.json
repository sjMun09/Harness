{
  "v": 1,
  "_comment": "Generic template for dynamos-configuration, dynamos-monitoring, dynamosconvert (109MB JS), and any repo without a language-specific template. Reads everything, writes/edits ask, secrets deny, git push deny. Appropriate for config-heavy and mixed repos.",
  "model": "claude-opus-4-7",
  "provider": "anthropic",
  "permissions": {
    "deny": [
      "Read(**/.env)", "Read(**/.env.*)", "Read(**/*.pem)", "Read(**/*.key)",
      "Read(**/.ssh/**)", "Read(**/credentials.json)", "Read(**/vault.yml)",
      "Read(**/vault/**)", "Read(**/secrets/**)",
      "Write(**/.env)", "Write(**/.env.*)", "Write(**/*.pem)", "Write(**/*.key)",
      "Write(**/.ssh/**)", "Write(**/credentials.json)",
      "Edit(**/.env)", "Edit(**/.env.*)", "Edit(**/*.pem)", "Edit(**/*.key)",
      "Edit(**/.ssh/**)", "Edit(**/credentials.json)",
      "Bash(git push)", "Bash(git push --force)", "Bash(git push -f)",
      "Bash(git push origin main)", "Bash(git push origin dev)", "Bash(git push origin qa)",
      "Bash(git push origin HEAD:main)", "Bash(git push origin HEAD:dev)", "Bash(git push origin HEAD:qa)"
    ],
    "allow": [
      "Read(**)", "Glob(**)", "Grep(**)",
      "Bash(ls)", "Bash(pwd)", "Bash(cat)", "Bash(head)", "Bash(tail)", "Bash(wc)",
      "Bash(file)", "Bash(stat)", "Bash(tree)",
      "Bash(git status)", "Bash(git log)", "Bash(git diff)", "Bash(git show)",
      "Bash(git branch)", "Bash(git blame)", "Bash(git remote)", "Bash(git fetch)",
      "Bash(git rev-parse)", "Bash(git ls-files)",
      "Bash(gh pr create)", "Bash(gh pr view)", "Bash(gh pr list)", "Bash(gh pr checks)",
      "Bash(gh issue list)", "Bash(gh issue view)",
      "Bash(jq)",
      "Bash(yq)",
      "Bash(diff)",
      "Bash(sort)",
      "Bash(uniq)"
    ],
    "ask": [
      "Write(**)", "Edit(**)",
      "Bash(scp)", "Bash(rsync)", "Bash(ssh)", "Bash(sftp)",
      "Bash(rm)", "Bash(mv)", "Bash(cp)", "Bash(chmod)", "Bash(chown)", "Bash(sudo)",
      "Bash(curl -X POST)",
      "Bash(curl -X PUT)",
      "Bash(curl -X DELETE)",
      "Bash(wget)"
    ]
  },
  "harness": {
    "plan_gate": {
      "enabled": true,
      "patterns": ["**/*.xml", "**/*.ftl", "**/*.sql", "**/migrations/**", "**/*.yml", "**/*.yaml"],
      "tools": ["Edit", "Write"]
    }
  }
}
