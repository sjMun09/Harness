{
  "v": 1,
  "_comment": "Python template (dynamos-llm, pytest+venv, main branch). pytest and read-only pip are allow; pip install / uninstall / upgrade are ask because they mutate the venv. Note: Bash(pip install) matches 'pip install -r requirements.txt' via shlex prefix — intended.",
  "model": "claude-opus-4-7",
  "provider": "anthropic",
  "permissions": {
    "deny": [
      "Read(**/.env)", "Read(**/.env.*)", "Read(**/*.pem)", "Read(**/*.key)",
      "Read(**/.ssh/**)", "Read(**/credentials.json)", "Read(**/vault.yml)",
      "Read(**/vault/**)", "Read(**/secrets/**)",
      "Write(**/.env)", "Write(**/.env.*)", "Write(**/*.pem)", "Write(**/*.key)",
      "Write(**/.ssh/**)", "Write(**/credentials.json)",
      "Edit(**/.env)", "Edit(**/.env.*)", "Edit(**/*.pem)", "Edit(**/*.key)",
      "Edit(**/.ssh/**)", "Edit(**/credentials.json)",
      "Bash(git push)", "Bash(git push --force)", "Bash(git push -f)",
      "Bash(git push origin main)", "Bash(git push origin dev)", "Bash(git push origin qa)",
      "Bash(git push origin HEAD:main)", "Bash(git push origin HEAD:dev)", "Bash(git push origin HEAD:qa)",
      "Bash(pip publish)",
      "Bash(twine upload)",
      "Bash(poetry publish)"
    ],
    "allow": [
      "Read(**)", "Glob(**)", "Grep(**)",
      "Bash(ls)", "Bash(pwd)", "Bash(cat)", "Bash(head)", "Bash(tail)", "Bash(wc)",
      "Bash(file)", "Bash(stat)", "Bash(tree)",
      "Bash(git status)", "Bash(git log)", "Bash(git diff)", "Bash(git show)",
      "Bash(git branch)", "Bash(git blame)", "Bash(git remote)", "Bash(git fetch)",
      "Bash(git rev-parse)", "Bash(git ls-files)",
      "Bash(gh pr create)", "Bash(gh pr view)", "Bash(gh pr list)", "Bash(gh pr checks)",
      "Bash(gh issue list)", "Bash(gh issue view)",
      "Bash(pytest)",
      "Bash(python -m pytest)",
      "Bash(python3 -m pytest)",
      "Bash(python -m unittest)",
      "Bash(python3 -m unittest)",
      "Bash(python --version)",
      "Bash(python3 --version)",
      "Bash(pip list)",
      "Bash(pip show)",
      "Bash(pip freeze)",
      "Bash(pip check)",
      "Bash(ruff check)",
      "Bash(ruff format --check)",
      "Bash(black --check)",
      "Bash(mypy)"
    ],
    "ask": [
      "Write(**)", "Edit(**)",
      "Bash(scp)", "Bash(rsync)", "Bash(ssh)", "Bash(sftp)",
      "Bash(rm)", "Bash(mv)", "Bash(cp)", "Bash(chmod)", "Bash(chown)", "Bash(sudo)",
      "Bash(pip install)",
      "Bash(pip uninstall)",
      "Bash(pip download)",
      "Bash(pip wheel)",
      "Bash(poetry install)",
      "Bash(poetry add)",
      "Bash(poetry remove)",
      "Bash(uv pip install)",
      "Bash(uv pip sync)",
      "Bash(python setup.py)",
      "Bash(python3 setup.py)"
    ]
  },
  "harness": {
    "plan_gate": {
      "enabled": true,
      "patterns": ["**/*.xml", "**/*.ftl", "**/*.sql", "**/migrations/**", "**/alembic/**"],
      "tools": ["Edit", "Write"]
    }
  }
}
