      "Bash(kubectl rollout undo)",
      "Bash(helm install)",
      "Bash(helm upgrade)",
      "Bash(helm uninstall)",
      "Bash(helm rollback)",
      "Bash(docker rm)",
      "Bash(docker rmi)",
      "Bash(docker system prune)",
      "Bash(docker volume rm)",
      "Bash(docker image prune)",
      "Bash(aws s3 rm)",
      "Bash(aws s3 cp)",
      "Bash(aws s3 sync)",
      "Bash(aws iam)",
      "Bash(aws ec2 terminate-instances)",
      "Bash(aws ec2 stop-instances)",
      "Bash(aws rds delete-db-instance)",
      "Bash(gcloud iam)",
      "Bash(gcloud compute instances delete)",
      "Bash(gh release create)",
      "Bash(gh workflow run)",
      "Bash(gh secret set)",
      "Bash(gh secret delete)",
      "Bash(gh repo delete)",
      "Bash(gh api -X POST)",
      "Bash(gh api -X PUT)",
      "Bash(gh api -X DELETE)",
      "Bash(gh api -X PATCH)"
    ]
  },
  "harness": {
    "plan_gate": {
      "enabled": true,
      "patterns": [
        "**/*.yml",
        "**/*.yaml",
        "**/*.j2",
        "**/playbooks/**",
        "**/roles/**"
      ],
      "tools": [
        "Edit",
        "Write"
      ]
    }
  },
  "hooks": {
    "pre_tool_use": [
      {
        "event": "pre_tool_use",
        "command": "bash scripts/harness-git-push-guard.sh",
        "timeout_ms": 3000,
        "on_timeout": "deny"
      }
    ]
  }
}
