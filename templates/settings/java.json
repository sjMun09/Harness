      "Bash(kubectl describe)",
      "Bash(kubectl logs)",
      "Bash(kubectl config view)",
      "Bash(kubectl version)",
      "Bash(helm list)",
      "Bash(helm status)",
      "Bash(helm show)",
      "Bash(helm version)",
      "Bash(docker ps)",
