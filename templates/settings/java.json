  "harness": {
    "plan_gate": {
      "enabled": true,
      "patterns": [
        "**/*.xml",
        "**/*.ftl",
        "**/*.sql",
        "**/migrations/**",
        "**/pom.xml"
      ],
      "tools": [
        "Edit",
        "Write"
      ]
    }
  },
  "hooks": {
    "pre_tool_use": [
      {
        "event": "pre_tool_use",
        "command": "bash scripts/harness-git-push-guard.sh",
        "timeout_ms": 3000,
        "on_timeout": "deny"
      }
    ]
  }
}
