{
  "v": 1,
  "_comment": "Base policy \u2014 inherited intent shared by every language template. Harness merges by concatenating rule vectors (see crates/harness-core/src/config.rs merge()), so _base.json is conceptually the 'common rules' that each concrete template ALREADY INCLUDES inline. Do not ship this file to a repo on its own; it is a reference. Key invariants: reads always allow, writes ask, secrets deny, git push deny except via gh pr create, remote-write asks.",
  "model": "claude-opus-4-7",
  "provider": "anthropic",
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/.ssh/**)",
      "Read(**/credentials.json)",
      "Read(**/vault.yml)",
      "Read(**/vault/**)",
      "Read(**/secrets/**)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/.ssh/**)",
      "Write(**/credentials.json)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/.ssh/**)",
      "Edit(**/credentials.json)",
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force-with-lease)",
      "Bash(terraform destroy)",
      "Bash(docker push)",
      "Bash(docker run --privileged)",
      "Bash(gh release delete)",
      "Bash(gh workflow disable)"
    ],
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(cat)",
      "Bash(head)",
      "Bash(tail)",
      "Bash(wc)",
      "Bash(file)",
      "Bash(stat)",
      "Bash(tree)",
      "Bash(git status)",
      "Bash(git log)",
      "Bash(git diff)",
      "Bash(git show)",
      "Bash(git branch)",
      "Bash(git blame)",
      "Bash(git remote)",
      "Bash(git fetch)",
      "Bash(git rev-parse)",
      "Bash(git ls-files)",
      "Bash(gh pr create)",
      "Bash(gh pr view)",
      "Bash(gh pr list)",
      "Bash(gh pr checks)",
      "Bash(gh issue list)",
      "Bash(gh issue view)",
      "Bash(terraform plan)",
      "Bash(terraform validate)",
      "Bash(terraform fmt -check)",
      "Bash(terraform show)",
      "Bash(terraform state list)",
      "Bash(terraform version)",
      "Bash(kubectl get)",
      "Bash(kubectl describe)",
      "Bash(kubectl logs)",
      "Bash(kubectl config view)",
      "Bash(kubectl version)",
      "Bash(helm list)",
      "Bash(helm status)",
      "Bash(helm show)",
      "Bash(helm version)",
      "Bash(docker ps)",
      "Bash(docker images)",
      "Bash(docker inspect)",
      "Bash(docker logs)",
      "Bash(docker version)",
      "Bash(aws s3 ls)",
      "Bash(aws sts get-caller-identity)",
      "Bash(gcloud auth list)",
      "Bash(gcloud config list)",
      "Bash(gh api repos)",
      "Bash(gh api user)"
    ],
    "ask": [
      "Write(**)",
      "Edit(**)",
      "Bash(git push)",
      "Bash(scp)",
      "Bash(rsync)",
      "Bash(ssh)",
      "Bash(sftp)",
      "Bash(rm)",
      "Bash(mv)",
      "Bash(cp)",
      "Bash(chmod)",
      "Bash(chown)",
      "Bash(sudo)",
      "Bash(terraform apply)",
      "Bash(terraform state rm)",
      "Bash(kubectl apply)",
      "Bash(kubectl delete)",
      "Bash(kubectl exec)",
      "Bash(kubectl replace)",
      "Bash(kubectl patch)",
      "Bash(kubectl edit)",
      "Bash(kubectl rollout undo)",
      "Bash(helm install)",
      "Bash(helm upgrade)",
      "Bash(helm uninstall)",
      "Bash(helm rollback)",
      "Bash(docker rm)",
      "Bash(docker rmi)",
      "Bash(docker system prune)",
      "Bash(docker volume rm)",
      "Bash(docker image prune)",
      "Bash(aws s3 rm)",
      "Bash(aws s3 cp)",
      "Bash(aws s3 sync)",
      "Bash(aws iam)",
      "Bash(aws ec2 terminate-instances)",
      "Bash(aws ec2 stop-instances)",
      "Bash(aws rds delete-db-instance)",
      "Bash(gcloud iam)",
      "Bash(gcloud compute instances delete)",
      "Bash(gh release create)",
      "Bash(gh workflow run)",
      "Bash(gh secret set)",
      "Bash(gh secret delete)",
      "Bash(gh repo delete)",
      "Bash(gh api -X POST)",
      "Bash(gh api -X PUT)",
      "Bash(gh api -X DELETE)",
      "Bash(gh api -X PATCH)"
    ]
  },
  "hooks": {
    "_comment": "Layer 2 of the branch-protection stack (see templates/settings/README.md). PreToolUse hook intercepts every Bash(git push) and refuses pushes targeting main/dev/qa. Layer 1 (scripts/git-hooks/pre-push) is client-side git. Layer 3 (templates/github/enforce-pr-only.yml) is a GitHub Actions alarm. All three are needed when server-side Branch Protection / Rulesets APIs are unavailable \u2014 they are gated behind the Team/Enterprise tier for private repos on Free. On Team/Enterprise use a real Ruleset and drop Layer 3.",
    "pre_tool_use": [
      {
        "event": "pre_tool_use",
        "command": "bash templates/settings/hooks/git_push_guard.sh",
        "timeout_ms": 3000,
        "on_timeout": "deny"
      }
    ]
  },
  "harness": {
    "plan_gate": {
      "enabled": true,
      "patterns": [
        "**/*.xml",
        "**/*.ftl",
        "**/*.sql",
        "**/migrations/**"
      ],
      "tools": [
        "Edit",
        "Write"
      ]
    }
  }
}
